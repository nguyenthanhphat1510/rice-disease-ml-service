# Đường dẫn file model YOLO classification (.pt train bằng Ultralytics)
MODEL_PATH=models/rice_disease.pt

# Kích thước ảnh đầu vào — khớp imgsz lúc train YOLO-cls (mặc định 224)
IMG_SIZE=224

# Thiết bị chạy: cpu | cuda:0  (để trống = tự dò GPU)
# DEVICE=cpu

# Số class trả về theo confidence giảm dần
TOP_K=3

# Port chạy uvicorn
PORT=8000
